@page "/"
@using MudBlazor
@inherits Honua.Admin.Shared.AdminPageBase
@implements IDisposable
@inject IAdminRealtimeConnection Realtime
@inject IAdminRealtimeEvents RealtimeEvents

<PageTitle>Honua Server Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h3" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Class="mr-3" />
        Honua Server Administration
    </MudText>

    <ErrorBanner Message="@ErrorMessage" />

    @if (IsLoading)
    {
        <MudGrid>
            @for (var i = 0; i < 4; i++)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="120px" Animation="Animation.Wave" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (_overview is not null)
    {
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudText Typo="Typo.overline">Edition</MudText>
                        <MudText Typo="Typo.h4">@_overview.CurrentEdition</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudText Typo="Typo.overline">Enabled features</MudText>
                        <MudText Typo="Typo.h4">@_overview.EnabledCount</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudText Typo="Typo.overline">Gated features</MudText>
                        <MudText Typo="Typo.h4">@_overview.DisabledCount</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudText Typo="Typo.overline">Total features</MudText>
                        <MudText Typo="Typo.h4">@_overview.Features.Count</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.h5" Class="mt-8 mb-2">Operations pulse</MudText>
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudCard Elevation="1">
                    <MudCardContent>
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.overline">Recent errors</MudText>
                            @LiveChip()
                        </MudStack>
                        <MudText Typo="Typo.h5">@(_errors?.Errors.Count ?? 0)</MudText>
                        <MudText Typo="Typo.caption">@(LatestError?.Path ?? _errors?.InstanceId ?? "No recent errors")</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/observability" Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.MonitorHeart">
                            Observability
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudCard Elevation="1">
                    <MudCardContent>
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.overline">Migrations</MudText>
                            @LiveChip()
                        </MudStack>
                        <MudText Typo="Typo.h5">@(_migrations?.Status ?? "Unknown")</MudText>
                        <MudText Typo="Typo.caption">@(_migrations?.Message ?? "No migration status loaded")</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/operator/operations" Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Settings">
                            Operations
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudCard Elevation="1">
                    <MudCardContent>
                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.overline">Connection health</MudText>
                            @LiveChip()
                        </MudStack>
                        <MudText Typo="Typo.h5">@(_connectionHealth?.HealthStatus ?? "No update")</MudText>
                        <MudText Typo="Typo.caption">@ConnectionHealthCaption</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/operator/data-connections" Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Storage">
                            Connections
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.h5" Class="mt-8 mb-2">Platform features</MudText>
        <MudTable Items="_overview.Features" Dense="true" Hover="true" Elevation="1" aria-label="Feature overview">
            <HeaderContent>
                <MudTh>Feature</MudTh>
                <MudTh>Category</MudTh>
                <MudTh>Minimum edition</MudTh>
                <MudTh>Status</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Feature">
                    <MudText Typo="Typo.body2">@context.DisplayName</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                </MudTd>
                <MudTd DataLabel="Category">@context.Category</MudTd>
                <MudTd DataLabel="Minimum edition">@context.MinimumEdition</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@(context.IsEnabled ? Color.Success : Color.Warning)"
                             Variant="Variant.Outlined">
                        @(context.IsEnabled ? "Enabled" : context.UpgradeMessage ?? "Gated")
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }

    <MudText Typo="Typo.h5" Class="mt-8 mb-2">Quick links</MudText>
    <MudGrid>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1">
                <MudCardContent>
                    <MudText Typo="Typo.h6">Spec workspace</MudText>
                    <MudText Typo="Typo.body2">Walking-skeleton authoring for analyses, maps and apps.</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/operator/spec">Open</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1">
                <MudCardContent>
                    <MudText Typo="Typo.h6">Server info</MudText>
                    <MudText Typo="Typo.body2">Version, environment, capabilities and configuration audit.</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/server-info">Inspect</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="1">
                <MudCardContent>
                    <MudText Typo="Typo.h6">Connections</MudText>
                    <MudText Typo="Typo.body2">Database connections, secrets and connection health.</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/connections">Manage</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private FeatureOverview? _overview;
    private RecentErrorsResponse? _errors;
    private MigrationObservabilityResponse? _migrations;
    private DataConnectionHealthChangedEvent? _connectionHealth;

    private RecentErrorEntry? LatestError => _errors?.Errors.FirstOrDefault();

    private string ConnectionHealthCaption
    {
        get
        {
            if (_connectionHealth is null)
            {
                return "Awaiting connection health event";
            }

            var name = string.IsNullOrWhiteSpace(_connectionHealth.Name)
                ? _connectionHealth.ConnectionId.ToString()
                : _connectionHealth.Name;
            var lastChecked = _connectionHealth.LastHealthCheck?.ToString("u") ?? "just now";
            return $"{name} - {lastChecked}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Realtime.StateChanged += OnRealtimeStateChanged;
        RealtimeEvents.RecentErrorReceived += OnRecentErrorReceived;
        RealtimeEvents.MigrationStatusChanged += OnMigrationStatusChanged;
        RealtimeEvents.ConnectionHealthChanged += OnConnectionHealthChanged;
        Telemetry.PageNavigated("/", principalId: null);
        await ExecuteAsync(async () =>
        {
            _overview = await AdminClient.GetFeatureOverviewAsync(CancellationToken.None);
            _errors = await AdminClient.GetRecentErrorsAsync(CancellationToken.None);
            _migrations = await AdminClient.GetMigrationStatusAsync(CancellationToken.None);
        });
    }

    private RenderFragment LiveChip() => builder =>
    {
        if (Realtime.Status != AdminRealtimeConnectionStatus.Connected)
        {
            return;
        }

        builder.OpenComponent<MudChip<string>>(0);
        builder.AddAttribute(1, "Size", Size.Small);
        builder.AddAttribute(2, "Color", Color.Success);
        builder.AddAttribute(3, "Variant", Variant.Outlined);
        builder.AddAttribute(4, "ChildContent", (RenderFragment)(chipBuilder => chipBuilder.AddContent(5, "Live")));
        builder.CloseComponent();
    };

    private void OnRealtimeStateChanged()
        => _ = InvokeAsync(StateHasChanged);

    private void OnRecentErrorReceived(RecentErrorEntry entry)
        => _ = InvokeAsync(() =>
        {
            _errors = AdminRealtimeReducers.AddRecentError(_errors, entry);
            StateHasChanged();
        });

    private void OnMigrationStatusChanged(MigrationObservabilityResponse status)
        => _ = InvokeAsync(() =>
        {
            _migrations = status;
            StateHasChanged();
        });

    private void OnConnectionHealthChanged(DataConnectionHealthChangedEvent health)
        => _ = InvokeAsync(() =>
        {
            _connectionHealth = health;
            StateHasChanged();
        });

    public void Dispose()
    {
        Realtime.StateChanged -= OnRealtimeStateChanged;
        RealtimeEvents.RecentErrorReceived -= OnRecentErrorReceived;
        RealtimeEvents.MigrationStatusChanged -= OnMigrationStatusChanged;
        RealtimeEvents.ConnectionHealthChanged -= OnConnectionHealthChanged;
    }
}
