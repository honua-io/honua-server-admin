@page "/operator/operations"
@using Honua.Admin.Models.Admin
@using Honua.Admin.Services.Operations
@using MudBlazor
@inherits Honua.Admin.Shared.AdminPageBase
@implements IDisposable
@inject OperationsConsoleState State

<PageTitle>Operations console - Honua Server Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4" data-testid="operations-console-root">
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
            <MudText Typo="Typo.h4">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                Operations console
            </MudText>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@StatusColor(State.Status)" data-testid="operations-console-status">
                @State.Status
            </MudChip>
        </MudStack>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshAsync" Disabled="@IsBusy">
            Refresh
        </MudButton>
    </MudStack>

    <ErrorBanner Message="@ErrorMessage" />
    @if (!string.IsNullOrWhiteSpace(State.LastError))
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Filled" Class="mb-4" data-testid="operations-console-warning">
            @State.LastError
        </MudAlert>
    }

    @if (IsBusy && State.DeployPreflight is null)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="280px" Animation="Animation.Wave" />
    }
    else
    {
        <MudGrid Class="mb-4">
            <MudItem xs="12" md="3">
                <MudCard Elevation="1">
                    <MudCardContent>
                        <MudText Typo="Typo.overline">Rollout health</MudText>
                        <MudText Typo="Typo.h6">@State.ReleaseHealthLabel</MudText>
                        <MudText Typo="Typo.body2">@(State.DeployPreflight?.Message ?? SectionError("Deploy preflight") ?? "No preflight loaded")</MudText>
                        <MudText Typo="Typo.caption">@($"{State.DeployPreflight?.Environment ?? "unknown"} · {State.DeployPreflight?.InstanceName ?? "unknown"}")</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/deploy" Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.RocketLaunch">
                            Deploy
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudCard Elevation="1">
                    <MudCardContent>
                        <MudText Typo="Typo.overline">Drift</MudText>
                        <MudText Typo="Typo.h6">@State.DriftLabel</MudText>
                        <MudText Typo="Typo.body2">@(State.ManifestDrift?.BaselineVersionId ?? SectionError("Manifest drift") ?? "No baseline loaded")</MudText>
                        <MudText Typo="Typo.caption">@($"{State.PendingApprovals.Count} pending approval(s)")</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/operator/publishing" Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Publish">
                            Publishing
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudCard Elevation="1">
                    <MudCardContent>
                        <MudText Typo="Typo.overline">Release evidence</MudText>
                        <MudText Typo="Typo.h6">@State.ReleaseEvidenceLabel</MudText>
                        <MudText Typo="Typo.body2">@LatestGitOpsEvidence()</MudText>
                        <MudText Typo="Typo.caption">@MigrationEvidence()</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/server-info" Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.Info">
                            Server
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudCard Elevation="1">
                    <MudCardContent>
                        <MudText Typo="Typo.overline">Troubleshooting</MudText>
                        <MudText Typo="Typo.h6">@State.TroubleshootingLabel</MudText>
                        <MudText Typo="Typo.body2">@(State.TelemetryStatus?.OtlpEndpoint ?? SectionError("Telemetry") ?? "No OTLP endpoint")</MudText>
                        <MudText Typo="Typo.caption">@($"{State.RecentErrors?.InstanceId ?? "unknown instance"}")</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/observability" Variant="Variant.Text" Size="Size.Small" StartIcon="@Icons.Material.Filled.MonitorHeart">
                            Observability
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>

        @if (State.SectionErrors.Count > 0)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Outlined" Class="mb-4" data-testid="operations-section-errors">
                @string.Join("; ", State.SectionErrors.Select(error => $"{error.Key}: {error.Value}"))
            </MudAlert>
        }

        <MudGrid>
            <MudItem xs="12" lg="6">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Row AlignItems="AlignItems.Center" Class="mb-2">
                        <MudText Typo="Typo.h6">Release evidence</MudText>
                        <MudSpacer />
                        <MudButton Href="/deploy" Variant="Variant.Text" Size="Size.Small">Deploy control</MudButton>
                    </MudStack>
                    <MudSimpleTable Dense="true" Hover="true" aria-label="Release evidence summary">
                        <tbody>
                            <tr><td>Preflight</td><td>@(State.DeployPreflight?.Status ?? "unknown")</td></tr>
                            <tr><td>Version</td><td>@(State.DeployPreflight?.ServerVersion ?? "unknown")</td></tr>
                            <tr><td>Migration</td><td>@MigrationEvidence()</td></tr>
                            <tr><td>Latest manifest</td><td>@(State.LatestManifestVersion?.ManifestHash ?? "none")</td></tr>
                            <tr><td>Latest GitOps change</td><td>@LatestGitOpsEvidence()</td></tr>
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="6">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Row AlignItems="AlignItems.Center" Class="mb-2">
                        <MudText Typo="Typo.h6">Drift and approvals</MudText>
                        <MudSpacer />
                        <MudButton Href="/operator/publishing" Variant="Variant.Text" Size="Size.Small">Review</MudButton>
                    </MudStack>
                    @if (State.ManifestDrift?.Resources.Count > 0)
                    {
                        <MudTable Items="State.ManifestDrift.Resources" Dense="true" Hover="true" aria-label="Operations drift resources">
                            <HeaderContent>
                                <MudTh>Resource</MudTh>
                                <MudTh>Type</MudTh>
                                <MudTh>Actual</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Identifier.DisplayName</MudTd>
                                <MudTd>@context.DriftType</MudTd>
                                <MudTd>@ShortHash(context.ActualHash)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Text">
                            No manifest drift resources loaded.
                        </MudAlert>
                    }
                    @if (State.PendingApprovals.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle2" Class="mt-3">Pending approvals</MudText>
                        @foreach (var pending in State.PendingApprovals)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" Class="mr-1 mt-1">
                                @ShortHash(pending.ManifestHash)
                            </MudChip>
                        }
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="6">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Row AlignItems="AlignItems.Center" Class="mb-2">
                        <MudText Typo="Typo.h6">Recent failures</MudText>
                        <MudSpacer />
                        <MudButton Href="/observability" Variant="Variant.Text" Size="Size.Small">Errors</MudButton>
                    </MudStack>
                    @if (State.RecentErrors?.Errors.Count > 0)
                    {
                        <MudTable Items="State.RecentErrors.Errors" Dense="true" Hover="true" aria-label="Operations recent errors">
                            <HeaderContent>
                                <MudTh>Time</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Path</MudTh>
                                <MudTh>Message</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Timestamp.ToString("u")</MudTd>
                                <MudTd>@context.StatusCode</MudTd>
                                <MudTd>@context.Path</MudTd>
                                <MudTd>@context.Message</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Text">
                            No recent errors loaded.
                        </MudAlert>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="6">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Troubleshooting links</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem Href="/observability" Icon="@Icons.Material.Filled.Insights">
                            Logs, traces, metrics, and recent errors
                        </MudListItem>
                        <MudListItem Href="/deploy" Icon="@Icons.Material.Filled.RocketLaunch">
                            Promotion, rollback, and deploy operation evidence
                        </MudListItem>
                        <MudListItem Href="/operator/publishing" Icon="@Icons.Material.Filled.Publish">
                            Desired-vs-actual state, GitOps changes, and manifest approvals
                        </MudListItem>
                        <MudListItem Href="/server-info" Icon="@Icons.Material.Filled.Info">
                            Server configuration and admin OpenAPI
                        </MudListItem>
                    </MudList>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    protected override async Task OnInitializedAsync()
    {
        State.OnChanged += StateChanged;
        Telemetry.PageNavigated("/operator/operations", principalId: null);
        await RefreshAsync();
    }

    public void Dispose()
    {
        State.OnChanged -= StateChanged;
    }

    private bool IsBusy => IsLoading || State.Status == OperationsConsoleStatus.Loading;

    private Task RefreshAsync() => ExecuteAsync(() => State.RefreshAsync(CancellationToken.None));

    private void StateChanged() => InvokeAsync(StateHasChanged);

    private string? SectionError(string section)
        => State.SectionErrors.TryGetValue(section, out var message) ? message : null;

    private string LatestGitOpsEvidence()
    {
        var latest = State.LatestGitOpsChange;
        if (latest is null)
        {
            return SectionError("GitOps changes") ?? "No GitOps change loaded";
        }

        return $"{ShortHash(latest.CommitSha)} · {latest.Status}";
    }

    private string MigrationEvidence()
        => State.MigrationStatus is null
            ? SectionError("Migrations") ?? "No migration status loaded"
            : $"{State.MigrationStatus.Status} · {(State.MigrationStatus.UpgradeRequired ? "upgrade required" : "no upgrade")}";

    private static string ShortHash(string? value)
        => string.IsNullOrWhiteSpace(value)
            ? "none"
            : value.Length <= 12
                ? value
                : value[..12];

    private static Color StatusColor(OperationsConsoleStatus status) => status switch
    {
        OperationsConsoleStatus.Error => Color.Error,
        OperationsConsoleStatus.Loading => Color.Info,
        OperationsConsoleStatus.Partial => Color.Warning,
        _ => Color.Default
    };
}
