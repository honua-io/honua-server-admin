@using Honua.Admin.Models
@using MudBlazor
@inject IFormDeploymentService FormDeploymentService
@inject ISnackbar Snackbar
@inject ILogger<FormPreviewDialog> Logger

<MudDialog>
    <DialogContent>
        <MudContainer Class="pa-0">
            <MudTabs Elevation="1" Rounded="true" Color="Color.Primary">
                <!-- Form Preview -->
                <MudTabPanel Text="Mobile Preview" Icon="@Icons.Material.Filled.PhoneAndroid">
                    <MudGrid Class="mt-4">
                        <MudItem xs="12" md="8">
                            <!-- Mobile Form Preview -->
                            <MudPaper Elevation="2" Class="pa-4" Style="max-height: 600px; overflow-y: auto;">
                                <MudText Typo="Typo.h6" GutterBottom="true">
                                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="mr-2" />
                                    @FormName
                                </MudText>

                                @if (!string.IsNullOrEmpty(FormDescription))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                                        @FormDescription
                                    </MudText>
                                }

                                <!-- Render form questions -->
                                @foreach (var question in RenderableQuestions)
                                {
                                    <MudCard Elevation="1" Class="mb-3">
                                        <MudCardContent>
                                            @RenderQuestion(question)
                                        </MudCardContent>
                                    </MudCard>
                                }

                                <MudDivider Class="my-4" />

                                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center">
                                    <MudButton Variant="Variant.Filled"
                                              Color="Color.Primary"
                                              StartIcon="@Icons.Material.Filled.Send">
                                        Submit Form
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                              StartIcon="@Icons.Material.Filled.Save">
                                        Save Draft
                                    </MudButton>
                                </MudStack>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <!-- QR Code and Deployment Info -->
                            <MudPaper Elevation="2" Class="pa-4">
                                <MudText Typo="Typo.h6" GutterBottom="true">
                                    Mobile Access
                                </MudText>

                                <MudStack AlignItems="AlignItems.Center" Class="mb-4">
                                    <!-- QR Code would be generated here -->
                                    <MudPaper Elevation="1" Class="pa-4" Style="background: white;">
                                        <div style="width: 150px; height: 150px; border: 2px dashed #ccc; display: flex; align-items: center; justify-content: center;">
                                            <MudText Typo="Typo.caption" Align="Align.Center">
                                                QR Code<br/>Preview
                                            </MudText>
                                        </div>
                                    </MudPaper>

                                    <MudText Typo="Typo.caption" Align="Align.Center">
                                        Scan with Honua mobile app
                                    </MudText>
                                </MudStack>

                                <MudTextField Label="Form URL"
                                             Value="@PreviewUrl"
                                             Variant="Variant.Outlined"
                                             ReadOnly="true"
                                             Adornment="Adornment.End"
                                             AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                                             AdornmentColor="Color.Primary" />

                                <MudDivider Class="my-4" />

                                <MudText Typo="Typo.subtitle2" GutterBottom="true">
                                    Form Information
                                </MudText>

                                <MudStack Spacing="2">
                                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.caption">Form ID:</MudText>
                                        <MudText Typo="Typo.caption">@FormId</MudText>
                                    </MudStack>

                                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.caption">Version:</MudText>
                                        <MudText Typo="Typo.caption">@FormVersion</MudText>
                                    </MudStack>

                                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.caption">Questions:</MudText>
                                        <MudText Typo="Typo.caption">@RenderableQuestions.Count</MudText>
                                    </MudStack>

                                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.caption">Required Fields:</MudText>
                                        <MudText Typo="Typo.caption">@RequiredQuestionCount</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <!-- Validation Results -->
                <MudTabPanel Text="Validation" Icon="@Icons.Material.Filled.CheckCircle">
                    <MudGrid Class="mt-4">
                        <MudItem xs="12">
                            <MudText Typo="Typo.h6" GutterBottom="true">
                                Form Validation Results
                            </MudText>

                            @if (ValidationResults.Count != 0)
                            {
                                foreach (var result in ValidationResults)
                                {
                                    <MudAlert Severity="@GetValidationSeverity(result.Severity)" Class="mb-2">
                                        <MudStack>
                                            <MudText Typo="Typo.body2">
                                                <strong>@result.Message</strong>
                                            </MudText>

                                            @if (!string.IsNullOrEmpty(result.FieldName))
                                            {
                                                <MudText Typo="Typo.caption">
                                                    Field: @result.FieldName
                                                </MudText>
                                            }

                                            @if (!string.IsNullOrEmpty(result.Suggestion))
                                            {
                                                <MudText Typo="Typo.caption" Style="font-style: italic;">
                                                    💡 @result.Suggestion
                                                </MudText>
                                            }
                                        </MudStack>
                                    </MudAlert>
                                }
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Success">
                                    <MudStack Row AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                                        <MudText>
                                            <strong>Form validation passed!</strong> Your form is ready for deployment.
                                        </MudText>
                                    </MudStack>
                                </MudAlert>
                            }

                            <!-- Optimization Suggestions -->
                            <MudDivider Class="my-4" />

                            <MudText Typo="Typo.subtitle1" GutterBottom="true">
                                Mobile Optimization Tips
                            </MudText>

                            <MudStack Spacing="2">
                                <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Smartphone">
                                    <strong>Battery Optimization:</strong> Form includes geopoint capture and photo fields.
                                    Consider enabling low-power mode for extended field work.
                                </MudAlert>

                                <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Compress">
                                    <strong>Data Compression:</strong> Form uses efficient gRPC v2 protocols for
                                    60% smaller data transfers compared to traditional REST APIs.
                                </MudAlert>

                                <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.OfflineBolt">
                                    <strong>Offline Support:</strong> Form data is cached locally and synchronized
                                    automatically when network connectivity is restored.
                                </MudAlert>
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <!-- XForms XML -->
                <MudTabPanel Text="XForms XML" Icon="@Icons.Material.Filled.Code">
                    <MudGrid Class="mt-4">
                        <MudItem xs="12">
                            <MudText Typo="Typo.h6" GutterBottom="true">
                                Generated XForms XML
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                                This is the OpenRosa-compatible XForms XML that will be deployed to mobile devices.
                            </MudText>

                            <MudPaper Elevation="1" Class="pa-4" Style="background-color: #f5f5f5; max-height: 400px; overflow-y: auto;">
                                <code style="font-family: 'Consolas', 'Monaco', 'Courier New', monospace; font-size: 12px; white-space: pre-wrap;">
                                    @XFormsXml
                                </code>
                            </MudPaper>

                            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mt-2">
                                <MudStack Row AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" />
                                    <MudText Typo="Typo.caption">
                                        Compatible with ODK, KoBo Toolbox, and OpenRosa standard
                                    </MudText>
                                </MudStack>

                                <MudButton Variant="Variant.Outlined"
                                          Size="Size.Small"
                                          StartIcon="@Icons.Material.Filled.Download">
                                    Download XML
                                </MudButton>
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
            </MudTabs>
        </MudContainer>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
        <MudButton Color="Color.Success"
                  Variant="Variant.Filled"
                  StartIcon="@Icons.Material.Filled.Publish"
                  OnClick="DeployForm"
                  Disabled="isDeploying">
            @(isDeploying ? "Deploying..." : "Deploy Form")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public XlsForm Form { get; set; } = new();
    [Parameter] public FormPreview Preview { get; set; } = new();

    private bool isDeploying;

    private IReadOnlyList<XlsFormSurveyRow> RenderableQuestions => FormPreviewWorkflow.GetRenderableQuestions(Form);

    private IReadOnlyList<FormValidationResult> ValidationResults => Preview?.ValidationResults ?? Array.Empty<FormValidationResult>();

    private int RequiredQuestionCount => FormPreviewWorkflow.GetRequiredQuestionCount(Form);

    private string FormName => string.IsNullOrWhiteSpace(Form?.Name) ? "Untitled Form" : Form.Name;

    private string? FormDescription => Form?.Description;

    private string FormVersion => string.IsNullOrWhiteSpace(Form?.Version) ? "n/a" : Form.Version;

    private string FormId => string.IsNullOrWhiteSpace(Form?.Settings?.FormId) ? "n/a" : Form.Settings.FormId;

    private string PreviewUrl => string.IsNullOrWhiteSpace(Preview?.PreviewUrl) ? string.Empty : Preview.PreviewUrl!;

    private string XFormsXml => string.IsNullOrWhiteSpace(Form?.XFormsXml)
        ? "<!-- XForms XML will be generated when form is deployed -->"
        : Form.XFormsXml;

    private RenderFragment RenderQuestion(XlsFormSurveyRow question)
    {
        var questionLabel = string.IsNullOrWhiteSpace(question.Label) ? question.Name : question.Label;
        var questionType = string.IsNullOrWhiteSpace(question.Type) ? "text" : question.Type;
        var isRequired = string.Equals(question.Required, "yes", StringComparison.OrdinalIgnoreCase);

        return builder =>
        {
            builder.OpenElement(0, "div");

            // Question label
            builder.OpenComponent<MudText>(1);
            builder.AddAttribute(2, "Typo", Typo.subtitle2);
            builder.AddAttribute(3, "GutterBottom", true);
            builder.AddAttribute(4, "ChildContent", (RenderFragment)(labelBuilder =>
            {
                labelBuilder.AddContent(0, questionLabel);
                if (isRequired)
                {
                    labelBuilder.AddMarkupContent(1, " <span style='color: red;'>*</span>");
                }
            }));
            builder.CloseComponent();

            // Question hint
            if (!string.IsNullOrEmpty(question.Hint))
            {
                builder.OpenComponent<MudText>(5);
                builder.AddAttribute(6, "Typo", Typo.caption);
                builder.AddAttribute(7, "Color", Color.Secondary);
                builder.AddAttribute(8, "Class", "mb-2");
                builder.AddAttribute(9, "ChildContent", (RenderFragment)(hintBuilder =>
                {
                    hintBuilder.AddContent(0, question.Hint);
                }));
                builder.CloseComponent();
            }

            // Question input based on type
            switch (questionType)
            {
                case "text":
                case "string":
                    builder.OpenComponent<MudTextField<string>>(10);
                    builder.AddAttribute(11, "Variant", Variant.Outlined);
                    builder.AddAttribute(12, "Placeholder", $"Enter {questionLabel?.ToLowerInvariant() ?? question.Name}");
                    builder.CloseComponent();
                    break;

                case "integer":
                    builder.OpenComponent<MudNumericField<int?>>(10);
                    builder.AddAttribute(11, "Variant", Variant.Outlined);
                    builder.AddAttribute(12, "Placeholder", "Enter number");
                    builder.CloseComponent();
                    break;

                case "decimal":
                    builder.OpenComponent<MudNumericField<decimal?>>(10);
                    builder.AddAttribute(11, "Variant", Variant.Outlined);
                    builder.AddAttribute(12, "Placeholder", "Enter decimal number");
                    builder.CloseComponent();
                    break;

                case "select_one":
                    builder.OpenComponent<MudSelect<string>>(10);
                    builder.AddAttribute(11, "Variant", Variant.Outlined);
                    builder.AddAttribute(12, "AnchorOrigin", Origin.BottomCenter);
                    builder.AddAttribute(13, "ChildContent", (RenderFragment)(selectBuilder =>
                    {
                        // Add sample options
                        var choices = (Form?.Choices ?? Array.Empty<XlsFormChoiceRow>())
                            .Where(c => c.ListName == question.Choice)
                            .ToList();
                        if (choices.Any())
                        {
                            foreach (var choice in choices)
                            {
                                selectBuilder.OpenComponent<MudSelectItem<string>>(0);
                                selectBuilder.AddAttribute(1, "Value", choice.Name);
                                selectBuilder.AddAttribute(2, "ChildContent", (RenderFragment)(choiceBuilder =>
                                {
                                    choiceBuilder.AddContent(0, choice.Label);
                                }));
                                selectBuilder.CloseComponent();
                            }
                        }
                        else
                        {
                            selectBuilder.OpenComponent<MudSelectItem<string>>(0);
                            selectBuilder.AddAttribute(1, "Value", "option1");
                            selectBuilder.AddAttribute(2, "ChildContent", (RenderFragment)(cb => cb.AddContent(0, "Option 1")));
                            selectBuilder.CloseComponent();

                            selectBuilder.OpenComponent<MudSelectItem<string>>(0);
                            selectBuilder.AddAttribute(1, "Value", "option2");
                            selectBuilder.AddAttribute(2, "ChildContent", (RenderFragment)(cb => cb.AddContent(0, "Option 2")));
                            selectBuilder.CloseComponent();
                        }
                    }));
                    builder.CloseComponent();
                    break;

                case "date":
                    builder.OpenComponent<MudDatePicker>(10);
                    builder.AddAttribute(11, "Variant", Variant.Outlined);
                    builder.AddAttribute(12, "Label", "Select date");
                    builder.CloseComponent();
                    break;

                case "geopoint":
                    builder.OpenElement(10, "div");
                    builder.AddAttribute(11, "style", "border: 2px dashed #ccc; padding: 20px; text-align: center; border-radius: 4px;");
                    builder.OpenComponent<MudStack>(12);
                    builder.AddAttribute(13, "AlignItems", AlignItems.Center);
                    builder.AddAttribute(14, "Spacing", 2);
                    builder.AddAttribute(15, "ChildContent", (RenderFragment)(geoBuilder =>
                    {
                        geoBuilder.OpenComponent<MudIcon>(0);
                        geoBuilder.AddAttribute(1, "Icon", Icons.Material.Filled.LocationOn);
                        geoBuilder.AddAttribute(2, "Size", Size.Large);
                        geoBuilder.AddAttribute(3, "Color", Color.Primary);
                        geoBuilder.CloseComponent();

                        geoBuilder.OpenComponent<MudText>(4);
                        geoBuilder.AddAttribute(5, "ChildContent", (RenderFragment)(tb => tb.AddContent(0, "Tap to capture GPS location")));
                        geoBuilder.CloseComponent();

                        geoBuilder.OpenComponent<MudButton>(6);
                        geoBuilder.AddAttribute(7, "Variant", Variant.Outlined);
                        geoBuilder.AddAttribute(8, "StartIcon", Icons.Material.Filled.MyLocation);
                        geoBuilder.AddAttribute(9, "ChildContent", (RenderFragment)(bb => bb.AddContent(0, "Get Location")));
                        geoBuilder.CloseComponent();
                    }));
                    builder.CloseComponent();
                    builder.CloseElement();
                    break;

                case "image":
                    builder.OpenElement(10, "div");
                    builder.AddAttribute(11, "style", "border: 2px dashed #ccc; padding: 20px; text-align: center; border-radius: 4px;");
                    builder.OpenComponent<MudStack>(12);
                    builder.AddAttribute(13, "AlignItems", AlignItems.Center);
                    builder.AddAttribute(14, "Spacing", 2);
                    builder.AddAttribute(15, "ChildContent", (RenderFragment)(photoBuilder =>
                    {
                        photoBuilder.OpenComponent<MudIcon>(0);
                        photoBuilder.AddAttribute(1, "Icon", Icons.Material.Filled.PhotoCamera);
                        photoBuilder.AddAttribute(2, "Size", Size.Large);
                        photoBuilder.AddAttribute(3, "Color", Color.Primary);
                        photoBuilder.CloseComponent();

                        photoBuilder.OpenComponent<MudText>(4);
                        photoBuilder.AddAttribute(5, "ChildContent", (RenderFragment)(tb => tb.AddContent(0, "Take a photo")));
                        photoBuilder.CloseComponent();

                        photoBuilder.OpenComponent<MudButton>(6);
                        photoBuilder.AddAttribute(7, "Variant", Variant.Outlined);
                        photoBuilder.AddAttribute(8, "StartIcon", Icons.Material.Filled.CameraAlt);
                        photoBuilder.AddAttribute(9, "ChildContent", (RenderFragment)(bb => bb.AddContent(0, "Capture Photo")));
                        photoBuilder.CloseComponent();
                    }));
                    builder.CloseComponent();
                    builder.CloseElement();
                    break;

                case "note":
                    builder.OpenComponent<MudTextField<string>>(10);
                    builder.AddAttribute(11, "Variant", Variant.Outlined);
                    builder.AddAttribute(12, "Lines", 4);
                    builder.AddAttribute(13, "Placeholder", "Enter detailed notes");
                    builder.CloseComponent();
                    break;

                default:
                    builder.OpenComponent<MudTextField<string>>(10);
                    builder.AddAttribute(11, "Variant", Variant.Outlined);
                    builder.AddAttribute(12, "Placeholder", $"Enter {questionType}");
                    builder.CloseComponent();
                    break;
            }

            builder.CloseElement();
        };
    }

    private Severity GetValidationSeverity(FormValidationSeverity severity)
    {
        return severity switch
        {
            FormValidationSeverity.Error => Severity.Error,
            FormValidationSeverity.Warning => Severity.Warning,
            FormValidationSeverity.Info => Severity.Info,
            _ => Severity.Normal
        };
    }

    private void Close() => MudDialog.Close();

    private async Task DeployForm()
    {
        if (isDeploying)
        {
            return;
        }

        isDeploying = true;
        try
        {
            var result = await FormDeploymentService.DeployAsync(Form);
            if (!result.Succeeded)
            {
                Snackbar.Add(result.Message, Severity.Error);
                return;
            }

            Snackbar.Add(result.Message, Severity.Success);
            MudDialog.Close(DialogResult.Ok(result));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected deployment failure for form {FormId}.", FormId);
            Snackbar.Add("Unexpected deployment error. Please try again.", Severity.Error);
        }
        finally
        {
            isDeploying = false;
        }
    }
}
